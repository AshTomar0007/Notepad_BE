<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body>
    <div class = "main w-full min-h-screen bg-zinc-800 p-10">
        <a class = "text-blue-500 inline-block mb-10" href ="/">Go Back to Home</a>
        <form action="/edit" method = "post">
            <input class="block w-1/2 text-white rounded-md outline-none px-5 py-2 bg-zinc-600 " type = "text" placeholder ="Previous Name" name = "previous" value="<%= filename%>">
            <input class="block w-1/2 text-white rounded-md outline-none  px-5 mt-2 py-2 resize-none bg-zinc-600" placeholder="New Name" name = "new">
            <input class="mt-2 bg-yellow-600 px-5 py-2 rounded-md" type = "Submit" value = "Update Name">
        </form>
    </div>
</body>
</html>